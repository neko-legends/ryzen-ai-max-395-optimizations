+def _is_rocm_llama_runtime(binary: Optional[str] = None) -> bool:
+    """Best-effort ROCm/HIP detection for llama.cpp launch tuning."""
+    if os.environ.get("HIP_VISIBLE_DEVICES") is not None:
+        return True
+    if os.environ.get("ROCR_VISIBLE_DEVICES") is not None:
+        return True
+    try:
+        import torch
+
+        if getattr(torch.version, "hip", None) is not None:
+            return True
+        if "rocm" in getattr(torch, "__version__", "").lower():
+            return True
+    except Exception:
+        pass
+    if binary:
+        try:
+            bin_dir = Path(binary).resolve().parent
+            return (bin_dir / "ggml-hip.dll").exists() or (bin_dir / "amdhip64_7.dll").exists()
+        except OSError:
+            return False
+    return False
+
